<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="?android:attr/colorBackground">

    <ImageView
        android:id="@+id/icone_sobre"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_info_custom" 
        android:layout_marginBottom="32dp"
        android:contentDescription="@string/desc_icone_sobre" />

    <TextView
        android:id="@+id/texto_curso"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dados_curso"
        android:textAlignment="center"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/titulo_equipe"
        android:textAlignment="center"
        android:textSize="18sp"
        android:textStyle="italic"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/integrante_1"
        android:textAlignment="center"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

</LinearLayout>